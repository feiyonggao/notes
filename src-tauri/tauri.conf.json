{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notes",
  "version": "1.3.1",
  "identifier": "com.notes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Notes 一个好用的便签工具",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/feiyonggao/notes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGRjVDNjg5QkY4OUFCRDYKUldUV3E0bS9pY2IxdjBwZlFIYUtsQ1FEUWJldjNudmQ4Mms3QVBDeU1GWVo1ZmV2cEZCbllaN3AK"
    }
  }
}
